    <!-- Shown in system UI / Play; keep in sync with DnsVpnService + Play Console special-use declaration -->
    <!-- Play: separate from generic Terms — required prominent disclosure for VpnService (User Data policy). -->
    <string name="vpn_prominent_title">VPN connection (DNS protection)</string>
    <string name="vpn_prominent_body">AdShield uses Android’s VPN permission only to create a local network tunnel so your DNS requests can be sent through the ad-blocking server you choose. We do not use this to monetize, sell, or redirect traffic from other apps for advertising purposes.\n\nYou stay in control: connect and disconnect in this app. While connected, Android may show an ongoing notification and the system key icon — that is required so protection can keep running in the background.\n\nTraffic handling depends on the DNS provider you select; see their terms and our Privacy Policy. If you do not agree, tap “Not now” and do not connect.</string>
    <string name="vpn_prominent_accept">I understand — continue</string>
    <string name="vpn_prominent_decline">Not now</string>

    <string name="vpn_service_manifest_description">Keeps your DNS protection active while you are connected.</string>
    <string name="vpn_special_use_fgs_subtype" translatable="false">AdShield runs a short-lived local VPN tunnel for DNS only. A foreground service is required so blocking stays active when the app is in the background. An ongoing notification shows connection status as required by Android; the user should disconnect inside the app before expecting the tunnel to stop.</string>
    <string name="vpn_notification_channel_name">Connection status</string>
    <string name="vpn_notification_channel_description">Required while connected: Android needs this ongoing notification so DNS protection can keep running in the background. You should disconnect in the app before clearing it. Expand the notification for details.</string>
    <string name="vpn_notification_title">AdShield — Connected</string>
    <string name="vpn_notification_text">%1$s • Protection active in background. Tap to open. Disconnect in app to stop.</string>
    <string name="vpn_notification_big_text">Server: %1$s. AdShield is connected. This notification stays visible while protection runs so Android can keep the service in the background (like other VPN apps). You normally should not dismiss it until you tap Disconnect in the app—otherwise DNS blocking may stop. If your phone allows swiping it away, disconnect first.</string>
    <string name="notification_permission_rationale_title">Background connection</string>
    <string name="notification_permission_rationale_message">When you connect, AdShield needs permission to show notifications. Android uses this for the ongoing status you see while protection runs in the background. That notice explains you are connected and usually cannot be removed safely until you disconnect in the app.</string>
